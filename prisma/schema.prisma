generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model document {
  id          String   @id @default(cuid())
  title       String
  content     Json?    // The editor content structure (stores all elements)
  status      String   @default("draft") // Status enum: draft, published, etc.
  author_id   String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  template_id String?

  template    template? @relation(fields: [template_id], references: [id])
  resources   resource[] @relation("DocumentResources")

  @@map("documents")
}

model template {
  id            String   @id @default(cuid())
  name          String
  content       Json?     // Detailed template structure
  description   String?
  tags          String?   // Searchable tags
  counter_agent String?   // Target counter-party or organization type
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  documents   document[]
  rules       rule[]

  @@map("templates")
}

model rule {
  id          String   @id @default(cuid())
  name        String
  type        String    // e.g. "validation", "logic", "transformation"
  logic       String?   // The actual rule definition as string
  template_id String?   // If null, it's a global rule
  created_at  DateTime @default(now())

  template    template? @relation(fields: [template_id], references: [id])

  @@map("rules")
}

model resource {
  id          String   @id @default(cuid())
  name        String
  type        String    // file, url, text
  source_url  String?
  file_path   String?
  content     String?   // Scraped content or text
  created_at  DateTime @default(now())

  documents   document[] @relation("DocumentResources")

  @@map("resources")
}
